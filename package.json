{
  "name": "unfault",
  "displayName": "Unfault",
  "description": "Production readiness analysis and automated fixes for your code",
  "version": "0.1.3",
  "publisher": "unfault",
  "author": {
    "name": "Sylvain",
    "email": "sylvain@unfault.dev"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "production",
    "readiness",
    "observability",
    "resilience",
    "sre"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:java",
    "onCommand:unfault.analyzeFile",
    "onCommand:unfault.analyzeProject",
    "onCommand:unfault.showReadinessScore"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unfault.showHome",
        "title": "Unfault: Show Home",
        "icon": "$(home)"
      },
      {
        "command": "unfault.login",
        "title": "Unfault: Login"
      },
      {
        "command": "unfault.logout",
        "title": "Unfault: Logout"
      },
      {
        "command": "unfault.updateApiKey",
        "title": "Unfault: Update API Key"
      },
      {
        "command": "unfault.analyzeFile",
        "title": "Unfault: Analyze Current File"
      },
      {
        "command": "unfault.analyzeProject",
        "title": "Unfault: Analyze Entire Project"
      },
      {
        "command": "unfault.showReadinessScore",
        "title": "Unfault: Show Production Readiness Score"
      },
      {
        "command": "unfault.explainRule",
        "title": "Unfault: Explain Rule"
      },
      {
        "command": "unfault.applyFix",
        "title": "Unfault: Apply Fix"
      }
    ],
    "configuration": {
      "title": "Unfault",
      "properties": {
        "unfault.analysisMode": {
          "type": "string",
          "enum": ["local", "cloud"],
          "default": "local",
          "description": "Analysis mode: local (development) or cloud (production)"
        },
        "unfault.autoAnalyze": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyze files on save"
        },
        "unfault.severityThreshold": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"],
          "default": "info",
          "description": "Minimum severity level to display"
        },
        "unfault.maxFileSize": {
          "type": "number",
          "default": 1048576,
          "description": "Maximum file size to analyze (bytes)"
        },
        "unfault.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules/**",
            "*.test.js",
            "*.test.py",
            ".git/**",
            "dist/**",
            "build/**"
          ],
          "description": "Glob patterns to exclude from analysis"
        },
        "unfault.enableInlineAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline annotations with fixes"
        }
      }
    },
    "colors": [
      {
        "id": "unfault.criticalSeverity",
        "description": "Color for critical severity findings",
        "defaults": {
          "dark": "#ff4444",
          "light": "#dd0000",
          "highContrast": "#ff0000"
        }
      },
      {
        "id": "unfault.highSeverity",
        "description": "Color for high severity findings",
        "defaults": {
          "dark": "#ff9944",
          "light": "#dd6600",
          "highContrast": "#ff8800"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:dev": "export NODE_ENV=development && tsc -p ./ && node build-config.js",
    "compile:prod": "export NODE_ENV=production && tsc -p ./ && node build-config.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "npm run compile:prod && vsce package"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unfault/vscode"
  },
  "license": "Apache-2.0"
}